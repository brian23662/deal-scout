# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# eBay Developer API
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_ENVIRONMENT=production

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_TO_NUMBER=+1xxxxxxxxxx

# Resend (email alerts)
RESEND_API_KEY=your_resend_api_key
ALERT_TO_EMAIL=your@email.com

# Apify (Facebook Marketplace)
APIFY_API_TOKEN=your_apify_token

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=make_up_a_long_random_string_here

# Deal scoring thresholds
MIN_PROFIT_DOLLARS=600
MIN_PROFIT_PERCENT=20
MAX_DISTANCE_MILES=240
HOME_ZIP=32174
